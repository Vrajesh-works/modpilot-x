{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modpilot-x",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Mop comments",
        "description": "Remove this comment and all child comments. This might take a few seconds to run.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-comment"
      },
      {
        "label": "Mop post comments",
        "description": "Remove all comments of this post. This might take a few seconds to run.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mop-post"
      },
      {
        "label": "View ModPilot X-Ray",
        "description": "See risk score, author profile, and text signals for this post.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/xray-post"
      },
      {
        "label": "View ModPilot X-Ray",
        "description": "See risk score, author profile, and text signals for this comment.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/xray-comment"
      },
      {
        "label": "Claim for review",
        "description": "Mark this item as being reviewed by you.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/claim-item"
      },
      {
        "label": "Claim for review",
        "description": "Mark this item as being reviewed by you.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/claim-item"
      },
      {
        "label": "Team Review Queue",
        "description": "See all items flagged for team review.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/team-queue"
      },
      {
        "label": "Send ModPilot Digest Now",
        "description": "Immediately send the daily digest.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/send-digest"
      },
      {
        "label": "Exit ModPilot Baseline Mode",
        "description": "Stop observation mode and start scoring immediately.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/exit-baseline"
      }
    ]
  },
  "forms": {
    "mopComment": "/internal/form/mop-comment-submit",
    "mopPost": "/internal/form/mop-post-submit",
    "xrayPost": "/internal/form/xray-post-submit",
    "xrayComment": "/internal/form/xray-comment-submit",
    "teamQueue": "/internal/form/team-queue-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onPostReport": "/internal/triggers/on-post-report",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": true,
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["discord.com"]
    }
  }
}
